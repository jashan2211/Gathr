rules_version = '2';

// Cloud Firestore security rules for Gathr.
// Paste this into Firebase Console -> Firestore Database -> Rules -> Publish.
//
// Security model for invites/RSVPs:
//  - The full event doc holds guest contact info and is OWNER-ONLY.
//  - A sanitized public projection (events/{id}/public/info) holds only
//    title/date/location and is readable by any signed-in user, including the
//    anonymous web visitors who open an invite link.
//  - A guest writes their response to events/{id}/rsvps/{guestId} and nothing
//    else; the host reads them back. Guest ids are unguessable UUIDs, so only
//    someone holding the actual invite link can write a meaningful response.
// Anything not matched below is denied by default.

service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles: any signed-in user can read a profile (a guest needs to
    // see a host's name), but you can only write your own.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // A user's private index of events they've been invited to. Only the
      // owner can read or write it.
      match /invitedEvents/{eventId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Discover: a top-level feed of lightweight PUBLIC event cards (no guest
    // list, no contact info) so Explore can surface public events created by
    // anyone. Any signed-in user can read the feed.
    //
    // A card may only be created or updated by the owner of the REAL event it
    // points at: the incoming ownerUid must be the caller AND the caller must
    // own events/{eventId}. This ties every card to an event the caller owns,
    // so nobody can flood the feed with cards for events they don't own, and
    // nobody can overwrite (hijack/deface) another owner's card. pushEvent
    // writes the event doc before the discover card, so the get() below sees a
    // committed events/{eventId} (Firestore commits a client's writes in order).
    //
    // Delete is keyed off the card's own ownerUid (not a get() on the event),
    // because deleteEvent removes the event doc first — the card must still be
    // removable afterwards. Only the card's owner could have created it, so
    // this stays owner-only.
    match /discover/{eventId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                            && request.resource.data.ownerUid == request.auth.uid
                            && get(/databases/$(database)/documents/events/$(eventId)).data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid;
    }

    // Events: the full document carries guest contact info, so only the owner
    // can read or write it.
    match /events/{eventId} {
      allow read: if request.auth != null
                  && resource.data.ownerUid == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.ownerUid == request.auth.uid;

      // Public projection: safe-to-share event details (no guest list). Any
      // signed-in user (incl. anonymous web visitors) can read it; only the
      // event owner can write it. The owner is checked against the doc's own
      // ownerUid field (no parent read — avoids a create-time race).
      match /public/{doc} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
                     && request.resource.data.ownerUid == request.auth.uid;
      }

      // RSVPs: a guest writes ONLY the document keyed by their own guest id,
      // with a validated shape. The event owner reads them all.
      match /rsvps/{guestId} {
        allow read: if request.auth != null
                    && get(/databases/$(database)/documents/events/$(eventId)).data.ownerUid == request.auth.uid;
        allow create, update: if request.auth != null
                    && guestId == request.resource.data.guestId
                    && request.resource.data.status in ['attending', 'maybe', 'declined']
                    && request.resource.data.partySize is int
                    && request.resource.data.partySize >= 0
                    && request.resource.data.partySize <= 20
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 120
                    && request.resource.data.keys().hasOnly(
                         ['guestId', 'status', 'partySize', 'name', 'note', 'respondedAt', 'source']
                       );
        // The event owner may delete an RSVP — used when a host removes a guest,
        // so the guest can't be re-created from an orphaned rsvp doc on next sync.
        allow delete: if request.auth != null
                      && get(/databases/$(database)/documents/events/$(eventId)).data.ownerUid == request.auth.uid;
      }

      // Per-function RSVPs: a guest writes their response to a specific function
      // (doc id "<functionId>_<guestId>"), validated. The event owner reads them
      // all to merge into the guest list. Same trust model as rsvps: guest ids
      // are unguessable, so only someone with the invite link can respond.
      match /functionRsvps/{docId} {
        allow read: if request.auth != null
                    && get(/databases/$(database)/documents/events/$(eventId)).data.ownerUid == request.auth.uid;
        allow create, update: if request.auth != null
                    && request.resource.data.functionId is string
                    && request.resource.data.guestId is string
                    && request.resource.data.response in ['yes', 'maybe', 'no']
                    && request.resource.data.partySize is int
                    && request.resource.data.partySize >= 0
                    && request.resource.data.partySize <= 20
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 120
                    && request.resource.data.keys().hasOnly(
                         ['functionId', 'guestId', 'response', 'partySize', 'name', 'note', 'respondedAt', 'source']
                       );
        allow delete: if request.auth != null
                      && get(/databases/$(database)/documents/events/$(eventId)).data.ownerUid == request.auth.uid;
      }

      // Activity feed: posts, questions, polls, announcements. Any signed-in user
      // can read the feed and create their own post (authorUid must be them).
      // Content edits (text/pin/soft-delete) are limited to the author or the
      // event owner; ANY signed-in user may react, but only by changing the
      // likedBy / pollVotes fields (enforced via diff().affectedKeys()).
      match /activity/{postId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.authorUid == request.auth.uid;
        allow update: if request.auth != null && (
                        resource.data.authorUid == request.auth.uid
                        || get(/databases/$(database)/documents/events/$(eventId)).data.ownerUid == request.auth.uid
                        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'pollVotes'])
                      );
        allow delete: if request.auth != null && (
                        resource.data.authorUid == request.auth.uid
                        || get(/databases/$(database)/documents/events/$(eventId)).data.ownerUid == request.auth.uid
                      );
      }

      // Team roster: private to the event owner (host's own devices). No guest
      // ever reads or writes it.
      match /members/{memberId} {
        allow read, write: if request.auth != null
                           && get(/databases/$(database)/documents/events/$(eventId)).data.ownerUid == request.auth.uid;
      }
    }
  }
}
